<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:data="clr-namespace:System.Data;assembly=System.Data"
    x:Class="DoyleAddin.Genius.Forms.GeniusiAssembly"
    d:DataContext="{d:DesignInstance Type=data:DataRowView, IsDesignTimeCreatable=False}" d:DesignWidth="538"
    d:DesignHeight="676" FontFamily="Tahoma" UseLayoutRounding="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DoyleAddin;component/Options/Themes/Elements.xaml" />
                <ResourceDictionary Source="/DoyleAddin;component/Options/Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid x:Name="grid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200*" />
            <ColumnDefinition Width="200*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="125" />
            <RowDefinition />
            <RowDefinition Height="55" />
        </Grid.RowDefinitions>
        <TabControl x:Name="tabControl" Grid.RowSpan="3" Style="{DynamicResource TabControlStyle}">
            <TabItem x:Name="MembersTab" Header="Members" BorderBrush="{x:Null}"
                     Foreground="{DynamicResource Menu.Static.Foreground}"
                     Background="{x:Null}">
                <DataGrid x:Name="Members"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.VerticalScrollBarVisibility="Visible"
                          ScrollViewer.HorizontalScrollBarVisibility="Visible"
                          AlternationCount="0"
                          SelectionChanged="ChildrenDataGrid_SelectionChanged"
                          Style="{DynamicResource CompleteDataGridStyle}" d:ItemsSource="{d:SampleData ItemCount=35}"
                          Margin="0,0,5,5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" IsReadOnly="True"
                                            CanUserSort="True" SortDirection="Ascending" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" IsReadOnly="True"
                                            CanUserSort="False" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem x:Name="AssemblyChildrenTab" Header="Assembly Children"
                     Foreground="{DynamicResource Menu.Static.Foreground}"
                     BorderBrush="{x:Null}" Background="{x:Null}" Margin="0,0,0,0">
                <DataGrid x:Name="MembersChildren"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.VerticalScrollBarVisibility="Visible"
                          ScrollViewer.HorizontalScrollBarVisibility="Visible"
                          AlternationCount="0"
                          SelectionChanged="ChildrenDataGrid1_SelectionChanged"
                          Style="{DynamicResource CompleteDataGridStyle}" d:ItemsSource="{d:SampleData ItemCount=35}"
                          Margin="0,0,0,5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" IsReadOnly="True"
                                            CanUserSort="True" SortDirection="Ascending" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" IsReadOnly="True"
                                            CanUserSort="False" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem x:Name="PurchasedTab" Header="Purchased" Foreground="{DynamicResource Menu.Static.Foreground}"
                     BorderBrush="{x:Null}" Background="{x:Null}" Margin="0,0,0,0">
                <DataGrid x:Name="PurchasedDataGrid"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.VerticalScrollBarVisibility="Visible"
                          ScrollViewer.HorizontalScrollBarVisibility="Visible"
                          AlternationCount="0"
                          SelectionChanged="PurchasedDataGrid_SelectionChanged"
                          Style="{DynamicResource CompleteDataGridStyle}" d:ItemsSource="{d:SampleData ItemCount=35}"
                          Margin="0,0,0,5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" IsReadOnly="True"
                                            CanUserSort="True" SortDirection="Ascending" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" IsReadOnly="True"
                                            CanUserSort="False" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
        <Border x:Name="ImageBorder" BorderBrush="{DynamicResource ImgBackground}" BorderThickness="2,2,2,2"
                Grid.Row="0" Grid.Column="1" CornerRadius="3,3,3,3" Width="100" Height="100" VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Image x:Name="image" Height="96" Width="96" Stretch="Fill" />
        </Border>
        <Grid x:Name="CompareDT" Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Label Content="Genius Properties" Foreground="{DynamicResource NormalText}"
                   VerticalContentAlignment="Center" FontSize="14" Margin="5,5,5,-5" />

            <DataGrid x:Name="SqlDataGrid"
                      Style="{DynamicResource CompleteDataGridStyle}" d:ItemsSource="{d:SampleData ItemCount=5}"
                      Grid.Row="1">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Property" Binding="{Binding Property}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Genius Value" Binding="{Binding [SQL Value]}" IsReadOnly="True"
                                        CanUserSort="False" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <Label Content="Inventor Properties" Foreground="{DynamicResource NormalText}"
                   Grid.Row="2" VerticalContentAlignment="Center" FontSize="14" Margin="5,5,5,-5" />

            <DataGrid x:Name="InventorDataGrid"
                      Style="{DynamicResource CompleteDataGridStyle}" d:ItemsSource="{d:SampleData ItemCount=5}"
                      Height="{Binding Height, ElementName=SqlDataGrid}"
                      Width="{Binding Width, ElementName=SqlDataGrid}" Grid.Row="3">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Property" Binding="{Binding Property}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Inventor Value" Binding="{Binding [Inventor Value]}"
                                        IsReadOnly="False" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

        </Grid>
        <StackPanel x:Name="Buttons" Grid.Column="1" Orientation="Vertical" Grid.Row="2" VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <Button x:Name="CalculatePropsButton" Content="Calculate Properties"
                    Click="CalculatePropsButton_Click" Height="20" Width="138" Margin="5,0,5,0"
                    Style="{DynamicResource ButtonStyle}" />
            <Button x:Name="Open_All_Parts" Content="Open All Parts"
                    Style="{DynamicResource ButtonStyle}" Height="20" />
        </StackPanel>
    </Grid>
</UserControl>