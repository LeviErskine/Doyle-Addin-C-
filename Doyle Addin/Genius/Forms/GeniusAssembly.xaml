<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:data="clr-namespace:System.Data;assembly=System.Data" x:Name="GeniusAssemblyPanel"
    mc:Ignorable="d"
    x:Class="DoyleAddin.Genius.Forms.GeniusAssembly"
    d:DataContext="{d:DesignInstance IsDesignTimeCreatable=False, Type={x:Type data:DataRowView}}" FontFamily="Tahoma"
    d:DesignWidth="420" d:DesignHeight="556" UseLayoutRounding="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DoyleAddin;component/Options/Themes/Elements.xaml" />
                <ResourceDictionary Source="/DoyleAddin;component/Options/Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200*" />
            <ColumnDefinition Width="200*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="125" />
            <RowDefinition />
            <RowDefinition Height="55" />
        </Grid.RowDefinitions>
        <TabControl x:Name="tabControl" Grid.RowSpan="3" Style="{DynamicResource TabControlStyle}" Grid.Column="0">
            <TabItem x:Name="AssembliesTab" Header="Assemblies" BorderBrush="{x:Null}"
                     Foreground="{DynamicResource Menu.Static.Foreground}"
                     Background="{x:Null}">
                <DataGrid x:Name="Assemblies"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.VerticalScrollBarVisibility="Visible"
                          ScrollViewer.HorizontalScrollBarVisibility="Visible"
                          AlternationCount="0"
                          SelectionChanged="SubassembliesDataGrid_SelectionChanged"
                          Style="{DynamicResource CompleteDataGridStyle}" d:ItemsSource="{d:SampleData ItemCount=35}"
                          Margin="0,0,5,5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" IsReadOnly="True"
                                            CanUserSort="True" SortDirection="Ascending" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" IsReadOnly="True"
                                            CanUserSort="False" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem x:Name="PartsTab" Header="Parts" Foreground="{DynamicResource Menu.Static.Foreground}"
                     BorderBrush="{x:Null}" Background="{x:Null}" Margin="0,0,0,0">
                <DataGrid x:Name="PartsDataGrid"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.VerticalScrollBarVisibility="Visible"
                          ScrollViewer.HorizontalScrollBarVisibility="Visible"
                          AlternationCount="0"
                          SelectionChanged="PartsDataGrid_SelectionChanged"
                          Style="{DynamicResource CompleteDataGridStyle}" d:ItemsSource="{d:SampleData ItemCount=35}"
                          Margin="0,0,0,5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" IsReadOnly="True"
                                            CanUserSort="True" SortDirection="Ascending" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" IsReadOnly="True"
                                            CanUserSort="False" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem x:Name="PurchasedTab" Header="Purchased" Foreground="{DynamicResource Menu.Static.Foreground}"
                     BorderBrush="{x:Null}" Background="{x:Null}" Margin="0,0,0,0">
                <DataGrid x:Name="PurchasedDataGrid"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.VerticalScrollBarVisibility="Visible"
                          ScrollViewer.HorizontalScrollBarVisibility="Visible"
                          AlternationCount="0"
                          SelectionChanged="PurchasedDataGrid_SelectionChanged"
                          Style="{DynamicResource CompleteDataGridStyle}" d:ItemsSource="{d:SampleData ItemCount=35}"
                          Margin="0,0,0,5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" IsReadOnly="True"
                                            CanUserSort="True" SortDirection="Ascending" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" IsReadOnly="True"
                                            CanUserSort="False" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
        <Border x:Name="ImageBorder" BorderBrush="{DynamicResource ImgBackground}" BorderThickness="2,2,2,2"
                Grid.Row="0" Grid.Column="1" CornerRadius="3,3,3,3" Width="100" Height="100" VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Image x:Name="image" Stretch="Fill" Width="96" Height="96" />
        </Border>
        <Grid x:Name="CompareDT" Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Label Content="Genius Properties" Foreground="{DynamicResource NormalText}"
                   VerticalContentAlignment="Center" FontSize="14" Margin="5,5,5,-5" />

            <DataGrid x:Name="SqlDataGrid"
                      Style="{DynamicResource CompleteDataGridStyle}" d:ItemsSource="{d:SampleData ItemCount=5}"
                      Grid.Row="1" IsReadOnly="True" Focusable="False">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Property" Binding="{Binding [Property]}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Genius Value" Binding="{Binding [SQL Value]}" IsReadOnly="True"
                                        CanUserSort="False" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <Label Content="Inventor Properties" Foreground="{DynamicResource NormalText}"
                   Grid.Row="2" VerticalContentAlignment="Center" FontSize="14" Margin="5,5,5,-5" />

            <DataGrid x:Name="InventorDataGrid"
                      Style="{DynamicResource CompleteDataGridStyle}" d:ItemsSource="{d:SampleData ItemCount=5}"
                      Height="{Binding Height, ElementName=SqlDataGrid}"
                      Width="{Binding Width, ElementName=SqlDataGrid}" Grid.Row="3"
                      CellEditEnding="InventorDataGrid_CellEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Property" Binding="{Binding [Property]}" IsReadOnly="True" />
                    <DataGridTextColumn Header="Inventor Value" Binding="{Binding [Inventor Value]}"
                                        IsReadOnly="False" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

        </Grid>
        <StackPanel x:Name="Buttons" Grid.Column="1" Orientation="Vertical" Grid.Row="2" HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <Button x:Name="CalculatePropsButton" Content="Calculate Properties"
                    Click="CalculatePropsButton_Click" Height="20" Width="138"
                    Style="{DynamicResource ButtonStyle}" Margin="5,0,5,0" />
            <Button x:Name="Open_All_Parts" Content="Open All Parts"
                    Click="Open_All_Parts_Click" Height="20" Width="138" Margin="5,5,5,5"
                    Style="{DynamicResource ButtonStyle}" />
        </StackPanel>
    </Grid>
</UserControl>