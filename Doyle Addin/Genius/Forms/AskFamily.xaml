<Window x:Name="window" x:Class="DoyleAddin.Genius.Forms.AskFamily"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d" Width="332" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Tahoma" FontSize="12"
        Foreground="{DynamicResource ThemedForegroundColor}" UseLayoutRounding="True" Topmost="True"
        SizeToContent="Height" Background="{DynamicResource BackgroundColorBrush}" WindowStyle="None"
        ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DoyleAddin;component/Options/Themes/DarkTheme.xaml" />
                <ResourceDictionary Source="/DoyleAddin;component/Options/Themes/Elements.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Storyboard x:Key="OpenTransition">
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="OtherPanel"
                                               Storyboard.TargetProperty="(FrameworkElement.LayoutTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                    <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0" />
                    <EasingDoubleKeyFrame KeyTime="00:00:00.1000000" Value="1" />
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>
            <Storyboard x:Key="CloseTransition">
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="OtherPanel"
                                               Storyboard.TargetProperty="(FrameworkElement.LayoutTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)">
                    <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1" />
                    <EasingDoubleKeyFrame KeyTime="00:00:00.1000000" Value="0" />
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>
        </ResourceDictionary>
    </Window.Resources>
    <Border x:Name="RoundCorners" CornerRadius="6,6,6,6" BorderThickness="2,2,2,2"
            BorderBrush="{DynamicResource BorderColorBrush}" d:LayoutOverrides="Width" Padding="5,5,5,5">
        <Grid UseLayoutRounding="False" Background="{x:Null}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Grid.Row="4" Grid.ColumnSpan="2" x:Name="OtherPanel" BorderThickness="1"
                    CornerRadius="5" Padding="1,1,1,1" UseLayoutRounding="True"
                    BorderBrush="{DynamicResource BorderColorBrush}" RenderTransformOrigin="0.5,0.5">
                <Border.LayoutTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleY="0" />
                        <SkewTransform />
                        <RotateTransform />
                        <TranslateTransform />
                    </TransformGroup>
                </Border.LayoutTransform>
                <StackPanel Margin="5,5,5,5">
                    <TextBlock Text="Select a Cost Center:" FontWeight="Bold"
                               Foreground="{DynamicResource ForegroundColorBrush}" Margin="0,0,0,8"
                               HorizontalAlignment="Left" />
                    <UniformGrid Columns="2">
                        <ComboBox x:Name="CostCenterComboBox"
                                  Style="{DynamicResource ComboBoxStyle}" Height="25"
                                  d:LayoutOverrides="LeftPosition, RightPosition" VerticalContentAlignment="Center" />
                        <CheckBox x:Name="SearchAllFamiliesCheckBox"
                                  Content="Search All Families"
                                  Foreground="{DynamicResource TextBox.Foreground}"
                                  Style="{DynamicResource CheckBoxStyle}" Width="119" VerticalContentAlignment="Center" />
                    </UniformGrid>
                    <Button x:Name="SelectFamilyButton" Content="Select" Width="100" Height="28"
                            HorizontalAlignment="Right" Margin="0,10,0,0"
                            Click="SelectFamilyButton_Click" Style="{DynamicResource ButtonStyle}" />
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Cost Center Mismatch" FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource TextBox.Foreground}" Margin="0,0,0,10" />

            <TextBlock Grid.Row="1" Grid.Column="0" TextWrapping="Wrap" Margin="0,0,0,8"
                       Foreground="{DynamicResource TextBox.Foreground}">
                <Run
                    Text="The Cost Center for this part does not match what Genius has on file. How would you like to proceed?" />
            </TextBlock>

            <Border Grid.Row="2" Grid.Column="0" BorderThickness="1"
                    CornerRadius="5" Margin="0,0,5,5" BorderBrush="{DynamicResource BorderColorBrush}">
                <Grid Background="{x:Null}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.ColumnSpan="2" Margin="5,5,0,8" Orientation="Horizontal"
                                d:LayoutOverrides="Width, Height">
                        <TextBlock Text="Current Value:" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBox.Foreground}" Height="14"
                                   VerticalAlignment="Center" Margin="0,0,5,0" HorizontalAlignment="Left" />
                        <TextBlock x:Name="InventorValueText"
                                   Foreground="{DynamicResource TextBox.Foreground}" Width="100"
                                   VerticalAlignment="Center" Margin="5,0,0,0" />
                    </StackPanel>
                    <StackPanel Grid.ColumnSpan="2" Grid.Column="0" Margin="5,0,0,5" Orientation="Horizontal"
                                Grid.Row="1" d:LayoutOverrides="Width, Height">
                        <TextBlock Text="Genius Value:" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBox.Foreground}" Margin="0,0,5,0"
                                   VerticalAlignment="Center" Width="87" />
                        <TextBlock x:Name="GeniusValueText" Foreground="#FF4CAF50" Width="100"
                                   VerticalAlignment="Center" Margin="5,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Grid.Column="0" Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button x:Name="YesButton" Content="Match Genius" Width="90" Height="28" Margin="0,0,8,0"
                        Click="YesButton_Click" Style="{DynamicResource ButtonStyle}" />
                <Button x:Name="NoButton" Content="Keep current" Width="90" Height="28" Margin="0,0,8,0"
                        Click="NoButton_Click" Style="{DynamicResource ButtonStyle}" />
                <Button x:Name="OtherButton" Content="Other..." Width="80" Height="28"
                        Click="OtherButton_Click" Style="{DynamicResource ButtonStyle}" Margin="0,5,5,5" />
            </StackPanel>
            <Border x:Name="ImageBorder" BorderBrush="{DynamicResource ImgBackground}" BorderThickness="2,2,2,2"
                    Grid.Row="0" Grid.Column="1" CornerRadius="3,3,3,3" Width="96" Height="96"
                    d:LayoutOverrides="Width" Grid.RowSpan="3" VerticalAlignment="Top">
                <Image x:Name="image" Width="96" Height="96" Stretch="Uniform" HorizontalAlignment="Left"
                       VerticalAlignment="Top" />
            </Border>
            <ContentControl Grid.Row="0" Grid.Column="0" Content="{DynamicResource OpenTransition}"
                            Visibility="Collapsed" />
            <ContentControl Grid.Row="0" Grid.Column="0" Content="{DynamicResource CloseTransition}"
                            Visibility="Collapsed" />
        </Grid>
    </Border>
</Window>