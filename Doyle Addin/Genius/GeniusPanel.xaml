<Window x:Class="Doyle_Addin.Genius.GeniusPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:genius="clr-namespace:Doyle_Addin.Genius" d:DataContext="{d:DesignInstance Type=genius:PartInfo+DocumentProperty}"
        mc:Ignorable="d"
        Title="Genius Panel"
        Width="450"
        Height="750"
        Activated="Window_Activated">

    <Window.Resources>
        <Style x:Key="HighlightRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasDifference, UpdateSourceTrigger=PropertyChanged}" Value="True">
                    <Setter Property="Background" Value="#FFCCCC" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top: Thumbnail Only -->
        <Border Background="White" BorderBrush="LightGray" BorderThickness="1" Width="128" Height="128" Margin="0,12">
            <Image x:Name="ThumbnailImage" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Height="128" Width="128" x:FieldModifier="protected" />
        </Border>

        <!-- Row 1: Genius Properties DataGrid -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock FontWeight="Bold" Text="Properties From Genius:" />
            <DataGrid
                x:Name="GeniusProperties"
                RowStyle="{StaticResource HighlightRowStyle}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="True"
                CanUserResizeRows="False"
                CanUserSortColumns="False"
                HeadersVisibility="Column"
                SelectionMode="Single"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Property" Binding="{Binding Property}" Width="Auto" IsReadOnly="True"
                                        CanUserReorder="False" CanUserResize="False" CanUserSort="False" />
                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" IsReadOnly="True"
                                        CanUserReorder="False" CanUserResize="False" CanUserSort="False" />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <!-- Row 2: Document Properties DataGrid -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Document Properties:" FontWeight="Bold" />
            <DataGrid
                x:Name="PropertiesDataGrid"
                RowStyle="{StaticResource HighlightRowStyle}"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeColumns="True"
                CanUserResizeRows="False"
                CanUserSortColumns="False"
                HeadersVisibility="Column"
                SelectionMode="Single"
                SelectionUnit="Cell"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True"
                MouseDoubleClick="PropertiesDataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Property" Binding="{Binding Property}" Width="Auto" IsReadOnly="True"
                                        CanUserReorder="False" CanUserResize="False" CanUserSort="False" />
                    <DataGridTextColumn Header="Value" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" IsReadOnly="True"
                                        CanUserReorder="False" CanUserResize="False" CanUserSort="False" />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <!-- Bottom: Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Update Properties" Width="120" Margin="0,0,8,0"
                    Click="CalculateProps_Click" />
            <Button Content="Save" Width="90" Margin="0,0,8,0" Click="SaveButton_Click" />
            <Button Content="Cancel" Width="90" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>